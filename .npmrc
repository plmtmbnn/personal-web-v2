# Use hoisted node_modules layout (like npm) instead of pnpm's default symlinked
# virtual store. This is required for Vercel's Serverless Function packager, which
# cannot follow symlinks when assembling deployment bundles and throws:
#   "The framework produced an invalid deployment package for a Serverless Function."
node-linker=hoisted

# Enable strict peer dependencies for faster resolution
strict-peer-dependencies=false

# Enable pnpm caching
cache-dir=.pnpm-cache

# Enable parallel installs
network-concurrency=16
